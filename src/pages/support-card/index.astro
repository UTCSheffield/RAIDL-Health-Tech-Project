---
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";

import { withBase } from "../../utils/helpers";
const SITE_URL = JSON.stringify(siteConfig.website + withBase('/support-card/'));
---

<MainLayout activePage="support-card" pageTitle={`${siteConfig.title} - Support Card`}>
  <style>
    :root{--text:#111;--muted:#555;--accent:#0b5;}
    body{font-family:Inter,system-ui,Arial,Helvetica,sans-serif;margin:18px;background:#f6f6f6;color:var(--text)}
    .wrap{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 420px;gap:18px;align-items:start}
    .panel{background:#fff;border-radius:10px;padding:18px;box-shadow:0 1px 0 rgba(0,0,0,.06)}
    label{display:block;font-weight:700;margin:10px 0 6px;color:var(--muted)}
    input,select,textarea{width:100%;padding:10px;border-radius:8px;border:1px solid #d0d0d0;font-size:16px;box-sizing:border-box}
    .controls{display:flex;gap:8px;margin-top:12px}
    button{background:var(--accent);color:#fff;border:none;padding:10px 12px;border-radius:8px;cursor:pointer;font-weight:700}
    .muted-btn{background:transparent;border:1px solid #d0d0d0;padding:8px 10px;border-radius:8px}
    .preview{border-radius:10px;padding:18px;display:flex;align-items:center;justify-content:center;background:#fff}
    .card-screen{width:360px;border-radius:8px;padding:14px;background:#fff;border:1px solid #e6e6e6}
    .card-title{font-size:20px;font-weight:800;margin-bottom:8px}
    .card-line{margin:8px 0;font-size:16px}
    .card-label{font-weight:800;color:var(--muted);display:block;font-size:12px;margin-bottom:4px}
    .small{font-size:13px;color:var(--muted);margin-top:8px}

    /* PRINT: single A4 page with front (left) and back (right) */
@media print {
  @page { size: A4 portrait; margin: 6mm; }
  html,body{height:100%;margin:0;padding:0}
  body{font-family:Arial,Helvetica,sans-serif;background:#fff;color:#111}

  /* sheet: full printable area (no gaps) */
.sheet{
  position:relative;
  width:calc(210mm - 12mm);
  height:calc(290mm - 12mm);
  margin:0 auto;
  padding:0;
  box-sizing:border-box;
  overflow:visible;
   max-height: 290mm;
     page-break-after: avoid;
  page-break-inside: avoid;
}
.print-note{
  position:absolute;
  left:0;
  right:0;
  bottom:6mm;
  text-align:center;
  font-size:10px;
  color:#111;
  font-weight:600;
  
}
 .sheet::before{
  content:"";
  position:absolute;
  left:50%;
  top:50%;
  height:54mm;              /* match wallet height */
  transform:translate(-0.125mm, -50%);
  width:0;
  border-left:0.5mm dashed black;
  pointer-events:none;
    z-index:5;
}
#form-title{
  font-family:"Caveat Brush", cursive;
}
.panel-card{
  position:absolute;
  top:50%;
  width:85mm;
  height:54mm;
  transform:translateY(-50%);
}

.panel-card.front{
  left:50%;
  transform:translate(-85mm,-50%);
}

.panel-card.back{
  left:50%;
  transform:translate(0,-50%);
}
  /* wallet card exact size */
  .wallet-area{
border:0.5mm solid #000;
    width:85mm;
    height:54mm;
    box-sizing:border-box;
  padding:4mm 6mm;
  padding-right:22mm;
    background:#fff;
    position:relative;
    z-index:4; 
    display:block;
  
  }
.panel-card.front .wallet-area::after{
  border-right:none;
}

.panel-card.back .wallet-area::after{
  border-left:none;
}


  .wallet-title{ font-weight:800; font-size:14px; margin-bottom:6px }
  .wallet-line{ font-size:12px; margin:4px 0 }
  .qr-label{ position:absolute; right:5mm; bottom:18mm; font-size:8px; color:#333; text-align:right; font-weight:600 }
  .qr{ position:absolute; right:5mm; bottom:5mm; width:11mm; height:11mm; display:block; object-fit:contain }

  /* print note: placed outside the sheet so it cannot overlay the wallets */
  .print-note{ display:block; width:100%; text-align:center; font-size:10px; color:#333; margin-top:6mm }

  body, .wrap { padding-left:0 !important; padding-right:0 !important }
}

    @media (max-width:1200px){ .wrap{ grid-template-columns:1fr } }
  </style>

  <div class="wrap">
    <div class="panel" aria-labelledby="form-title">
      <h1 id="form-title">Create a printable Support Card</h1>

      <label for="name">Name / Nickname</label>
      <input id="name" type="text" placeholder="John" />

      <label for="how">How I like to be told things</label>
      <select id="how">
        <option>One instruction at a time</option>
        <option>Show me first, then tell me</option>
        <option>Write it down</option>
        <option>Use visual steps</option>
        <option>Other</option>
      </select>

      <label for="sensory">Sensory triggers (short)</label>
      <input id="sensory" type="text" placeholder="loud noises, bright lights" />

      <label for="helps">What helps me (2 things)</label>
      <input id="helps" type="text" placeholder="Quiet space; a timer" />

      <label for="health">Health note (meds/time or 'none')</label>
      <input id="health" type="text" placeholder="Meds at 8:00 - methylphenidate" />

      <label for="confident">What builds my confidence (one short sentence)</label>
      <input id="confident" type="text" placeholder="Praise when I finish a step" />

      <label for="contact">Emergency contact (name + phone)</label>
      <input id="contact" type="text" placeholder="Alex - 07123 456789" />

      <div class="controls" role="group" aria-label="controls">
        <button id="printBtn">Print / Download</button>
        <button id="clear" class="muted-btn" style="color:black; width: 100px; font-weight: 500;">Clear</button>
      </div>


    </div>

    <div class="preview" aria-live="polite">
      <div class="card-screen" id="card-screen">
        <div class="card-title">My Support Card</div>
        <div class="card-line"><span class="card-label">Name:</span><span id="p-name">—</span></div>
        <div class="card-line"><span class="card-label">How I like to be told things:</span><span id="p-how">—</span></div>
        <div class="card-line"><span class="card-label">Sensory triggers:</span><span id="p-sensory">—</span></div>
        <div class="card-line"><span class="card-label">What helps me:</span><span id="p-helps">—</span></div>
        <div class="card-line"><span class="card-label">Health note:</span><span id="p-health">—</span></div>
        <div class="card-line"><span class="card-label">Emergency contact:</span><span id="p-contact">—</span></div>
        <div class="card-line small"><strong>How to use:</strong> Give this card to my teacher, carer or doctor.</div>
      </div>
    </div>
  </div>

<script>
// @ts-nocheck
(function () {
  // initialise whether DOMContentLoaded has already fired or not
  function init() {
    try {
      // helper + fields
      var $ = function(id){ return document.getElementById(id); };
      var fields = ['name','how','sensory','helps','health','confident','contact'];

      // Restore saved values (safe)
      try {
        var saved = JSON.parse(localStorage.getItem('supportCard') || '{}');
        for (var i = 0; i < fields.length; i++) {
          var f = fields[i];
          if (saved[f] && $(f)) { $(f).value = saved[f]; }
        }
      } catch (e) {
        console.warn('Failed to read localStorage for supportCard', e);
      }

      // update preview & persist
      function updatePreview(){
        for (var i = 0; i < fields.length; i++) {
          var f = fields[i];
          var v = ($(f) && $(f).value ? $(f).value.toString().trim() : '');
          var el = $('p-' + f);
          if (el) { el.textContent = v || '—'; }
        }
        try {
          var obj = {};
          for (var j = 0; j < fields.length; j++) { obj[fields[j]] = ($(fields[j]) ? $(fields[j]).value : ''); }
          localStorage.setItem('supportCard', JSON.stringify(obj));
        } catch (e) {
          console.warn('Failed to save supportCard to localStorage', e);
        }
      }

      updatePreview();

      // clear button
      if ($('clear')) {
        $('clear').addEventListener('click', function(){
          for (var i = 0; i < fields.length; i++) { if ($(fields[i])) $(fields[i]).value = ''; }
          updatePreview();
          try { localStorage.removeItem('supportCard'); } catch(e) {}
        });
      }

      // debounce inputs
      var debounceTimer;
      for (var k = 0; k < fields.length; k++) {
        (function(field){
          var el = $(field);
          if (!el) return;
          el.addEventListener('input', function(){
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(updatePreview, 180);
          });
        })(fields[k]);
      }

      function esc(s){
        if (!s) return '';
        return s.toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      // Print handler (safe)
      if ($('printBtn')) {
        $('printBtn').addEventListener('click', function (ev) {
          // keep this as a user-gesture handler; avoid async breaks before print call
          try {
            updatePreview();
            var data = {};
            for (var i = 0; i < fields.length; i++) {
              data[fields[i]] = ($(fields[i]) && $(fields[i]).value) ? $(fields[i]).value.toString().trim() : '—';
            }

            // determine siteUrl (meta tag fallback)
            var meta = document.querySelector('meta[name="site-url"]');
            var siteUrl = (meta && meta.getAttribute) ? meta.getAttribute('content') : window.location.origin + '/support-card/';
            console.log('support-card: using siteUrl =', siteUrl);
            var qrSrc = 'https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=' + encodeURIComponent(siteUrl);

            // build print HTML
            var html = '<!doctype html><html><head><meta charset="utf-8"><title>Support Card Print</title><style>';
            html += '@page{size:A4;margin:6mm}';
            html += 'body{font-family:Arial,Helvetica,sans-serif;margin:0;padding:0;color:#111;background:#fff}';
            html += '.sheet{position:relative;width:calc(210mm - 12mm);height:calc(297mm - 12mm); max-height: 290mm;  page-break-after: avoid;page-break-inside: avoid;margin:0;padding:0;box-sizing:border-box}';

            // centre dashed line
           html += '.sheet::before{content:"";position:absolute;left:50%;top:50%;height:60mm;transform:translate(-0.125mm,-50%);width:0;border-left:0.5mm dashed black;pointer-events:none;z-index:3;}';


html += '.panel-card{position:absolute;top:50%;width:85mm;height:54mm;display:block;transform:translateY(-50%)}';
html += '.panel-card.front{left:50%;transform:translate(-100%,-50%)}';
html += '.panel-card.back{left:50%;transform:translate(0,-50%)}';

html += '.wallet-area{'
html += 'width:85mm;'
html += 'height:54mm;'
html += 'box-sizing:border-box;'
html += 'padding:4mm 18mm 4mm 6mm;'
html += 'background:#fff;'
html += 'position:relative;'
html += '}';

html += '.wallet-area::after{'
html += 'content:"";'
html += 'position:absolute;'
html += 'inset:0;'
html += 'pointer-events:none;'
html += 'border:0.5mm solid #000;'
html += 'box-sizing:border-box;'
html += '}';

html += '.panel-card.front .wallet-area::after{border-right:none;}';
html += '.panel-card.back .wallet-area::after{border-left:none;}';





            html += '.wallet-title{font-weight:800;font-size:14px;margin-bottom:6px}';
            html += '.wallet-line{font-size:12px;margin:4px 0}';
            html += '.qr-label{position:absolute;right:4mm;bottom:16mm;font-size:8px;color:#333;text-align:right;font-weight:600}';
            html += '.qr{position:absolute;right:4mm;bottom:4mm;width:12mm;height:12mm;display:block}';
            html += '.print-note{display:block;width:100%;text-align:center;font-size:10px;color:#333;margin-top:6mm}';
            html += '.sheet{page-break-after:avoid}';
            html += '</style></head><body>';

            html += '<div class="sheet" role="main">';

            // FRONT
            html += '<div class="panel-card front" aria-label="Front">';
            html += '<div class="wallet-area">';

            html += '<div class="wallet-title">My Support Card</div>';
            html += '<div class="wallet-line"><strong>Name:</strong> ' + esc(data.name) + '</div>';
            html += '<div class="wallet-line"><strong>How I like to be told things:</strong> ' + esc(data.how) + '</div>';
            html += '<div class="wallet-line"><strong>What helps me:</strong> ' + esc(data.helps) + '</div>';
            html += '<div class="wallet-line"><strong>Health note:</strong> ' + esc(data.health) + '</div>';
            html += '<div class="wallet-line"><strong>Emergency:</strong> ' + esc(data.contact) + '</div>';
            html += '<div class="qr-label">Scan me to learn more!</div>';
            html += '<img class="qr" src="' + qrSrc + '" alt="QR linking to site" />';
            html += '</div>'; // wallet-area
            html += '</div>'; // panel-card
               
            // BACK
            html += '<div class="panel-card back" aria-label="Back">';
            html += '<div class="wallet-area">';

            html += '<div class="wallet-title">Emergency Info</div>';
            html += '<div class="wallet-line"><strong>Sensory triggers:</strong> ' + esc(data.sensory) + '</div>';
            html += '<div class="wallet-line"><strong>Confidence tip:</strong> ' + esc(data.confident) + '</div>';
            html += '</div>'; // wallet-area
            
            html += '</div>'; // panel-card
html += '<div class="print-note">Cut around the cards using </div>';
            html += '</div>'; // sheet

            // move print note outside the sheet so it cannot overlay the wallet
           

            html += '</body></html>';

            // open new window and attempt immediate print (keeps user gesture)
            var w = null;
            try {
              w = window.open('', '_blank');
            } catch (openErr) {
              console.warn('Popup open failed', openErr);
            }

            if (!w) {
              // popup blocked: navigate current window to blob URL as fallback (user will need to print manually)
              var blob = new Blob([html], {type: 'text/html'});
              var url = URL.createObjectURL(blob);
              window.location.href = url;
              return;
            }

            // write content
            try {
              w.document.open();
              w.document.write(html);
              w.document.close();

              try { w.focus(); } catch (e) {}

              // Try immediate print() while still inside user gesture chain.
              // This works in most browsers; if it throws, attach an onload fallback.
              try {
                if (typeof w.print === 'function') {
                  w.print();
                } else {
                  // fallback: call print on load
                  w.onload = function () {
                    try { w.print(); } catch (err2) { console.error('child.print failed (onload)', err2); }
                  };
                }
              } catch (printErr) {
                console.error('Immediate print() threw, attaching onload fallback', printErr);
                w.onload = function () {
                  try { w.print(); } catch (err3) { console.error('child.print failed (onload)', err3); }
                };
              }
            } catch (writeErr) {
              console.error('Failed to write child window HTML', writeErr);
              alert('Sorry — could not open the print preview. Check console for details.');
            }
          } catch (err) {
            console.error('Print handler error', err);
            alert('Sorry — an error occurred while preparing the print page. Check the console for details.');
          }
        });
      }

    } catch (outerErr) {
      console.error('Support card init error', outerErr);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    // already ready — run immediately
    init();
  }
})();
</script>


</MainLayout>