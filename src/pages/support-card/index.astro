---
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";
---

<MainLayout activePage="fun stuff" pageTitle={`${siteConfig.title} — Fun Stuff`}>
<style>
  /* Using project-wide theme tokens (no local color definitions) */

  /* rely on your global variables: --brand-primary, --brand-muted, --brand-light,
     --brand-dark, --page-light, --text-primary, --text-secondary, --text-muted, etc. */

  body {
    font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, Arial;
    margin: 18px;
    color: var(--text-primary);
    background: var(--page-light);
  }

  /* Responsive grid: main column + side preview that scales with viewport */
  .wrap {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr min(480px, 44vw); /* preview column will shrink on small screens */
    gap: 18px;
    align-items: start;
    padding: 6px;
    box-sizing: border-box;
  }

  /* Panels now use transparent fill and a black border as requested */
  .panel {
    background: transparent;               /* no filled background */
    border: 2px solid #000;                /* solid black border */
    border-radius: 12px;
    padding: 18px;
    box-shadow: none;                      /* keep it flat per your earlier calm aesthetic */
    box-sizing: border-box;
  }

  h1 {
    font-size: 1.25rem;
    margin: 0 0 10px 0;
    color: var(--brand-dark);
  }

  label {
    display: block;
    font-weight: 600;
    margin: 10px 0 6px 0;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  input[type=text], select, textarea {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--brand-muted) 85%, var(--brand-light) 15%);
    font-size: 0.95rem;
    background: transparent;
    color: var(--text-primary);
    box-sizing: border-box;
  }

  textarea { min-height: 64px; resize: vertical; }

  .small {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 6px;
  }

  .row { display:flex; gap:8px; }

  button {
    background: var(--brand-primary);
    color: var(--brand-light);
    border: none;
    padding: 10px 12px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
  }

  .muted-btn {
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--brand-muted) 70%, var(--brand-light) 30%);
    color: var(--brand-dark);
    padding: 8px 10px;
    border-radius: 8px;
    cursor: pointer;
  }

  /* Preview panel uses border (no fill) and keeps internal centering */
  .preview {
    background: transparent;               /* removed fill */
    border: 2px solid #000;                /* black border */
    border-radius: 10px;
    padding: 18px;
    min-height: 320px;                     /* slightly smaller min height for better fit */
    display:flex;
    align-items:center;
    justify-content:center;
    box-sizing: border-box;
  }

  /* card-screen becomes responsive: scale to available space up to a comfortable max */
  .card-screen {
    width: min(360px, 86%);                /* responsive width */
    max-width: 420px;                      /* safeguard for very wide preview columns */
    border-radius: 8px;
    border: 1px solid #000;                /* black border around the inner card too */
    padding: 14px;
    background: transparent;               /* remove inner fill */
    color: var(--text-primary);
    box-sizing: border-box;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--brand-dark);
  }

  .card-line {
    margin: 8px 0;
    font-size: 0.98rem;
    line-height: 1.35;
    color: var(--text-primary);
  }

  .card-label {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--text-muted);
    display:block;
    margin-bottom:4px;
  }

  .controls {
    display:flex;
    gap:8px;
    margin-top:12px;
    align-items:center;
  }

  input[type=checkbox] { width:18px; height:18px; }

  /* Stack cleanly on smaller screens and give preview full width */
  @media (max-width:1200px) {
    .wrap { grid-template-columns: 1fr; }
    .preview { order:-1; width: 100%; }
    .panel { order:2; width: 100%; }
  }

  /* Small screens: reduce margins & ensure card fills reasonably */
  @media (max-width:640px) {
    body { margin: 10px; }
    .wrap { gap: 12px; padding: 4px; }
    .card-screen { width: 92%; max-width: 380px; padding: 12px; }
    .panel { padding: 14px; border-width: 1px; }
    .preview { padding: 12px; border-width: 1px; min-height: 280px; }
  }

  /* NOTE: low-arousal mode removed as requested (no related styles) */
</style>

<div class="wrap">
  <div class="panel" aria-labelledby="form-title">
    <h1 id="form-title">Create a printable Support Card</h1>
    

    <label for="name">Name / Nickname</label>
    <input id="name" type="text" placeholder="John" />

    <label for="how">How I like to be told things</label>
    <select id="how">
      <option value="One instruction at a time">One instruction at a time</option>
      <option value="Show me first, then tell me">Show me first, then tell me</option>
      <option value="Write it down">Write it down</option>
      <option value="Use visual steps">Use visual steps</option>
      <option value="Other">Other</option>
    </select>

    <label for="sensory">Sensory triggers (short)</label>
    <input id="sensory" type="text" placeholder="loud noises, bright lights" />

    <label for="helps">What helps me (2 things)</label>
    <input id="helps" type="text" placeholder="Quiet space; a timer" />

    <label for="money">Money support (Yes/No) + short note</label>
    <input id="money" type="text" placeholder="No" />

    <label for="health">Health note (meds/time or 'none')</label>
    <input id="health" type="text" placeholder="Meds at 8:00 - methylphenidate" />

    <label for="confident">What helps me feel confident (one short sentence)</label>
    <input id="confident" type="text" placeholder="Praise when I finish a step" />

    <label for="contact">Emergency contact (name + phone)</label>
    <input id="contact" type="text" placeholder="Alex - 07123 456789" />

    <div class="controls" role="group" aria-label="controls">
      <button id="print">Print / Download</button>
      <button id="clear" class="muted-btn">Clear</button>
    </div>

   
  </div>

  <div class="" aria-live="polite">
    <div id="preview-area">
      <div class="card-screen" id="card-screen">
        <div class="card-title">My Support Card</div>
        <div class="card-line"><span class="card-label">Name:</span> <span id="p-name">—</span></div>
        <div class="card-line"><span class="card-label">How I like to be told things:</span> <span id="p-how">—</span></div>
        <div class="card-line"><span class="card-label">Sensory triggers:</span> <span id="p-sensory">—</span></div>
        <div class="card-line"><span class="card-label">What helps me:</span> <span id="p-helps">—</span></div>
        <div class="card-line"><span class="card-label">Money support:</span> <span id="p-money">—</span></div>
        <div class="card-line"><span class="card-label">Health note:</span> <span id="p-health">—</span></div>
        <div class="card-line"><span class="card-label">What builds my confidence:</span> <span id="p-confident">—</span></div>
        <div class="card-line"><span class="card-label">Emergency contact:</span> <span id="p-contact">—</span></div>
        <div class="card-line" style="margin-top:12px; font-size:0.9rem; color:var(--text-muted);"><strong>How to use:</strong> Give this card to my teacher, carer or doctor.</div>
      </div>
    </div>
  </div>
</div>

<script>
  // Short helpers
  const $ = id => document.getElementById(id);
  const fields = ['name','how','sensory','helps','money','health','confident','contact'];

  // Restore saved values if any
  try {
    const saved = JSON.parse(localStorage.getItem('supportCard') || '{}');
    fields.forEach(f => { if (saved[f]) $(f).value = saved[f]; });
  } catch(e) { /* ignore */ }

  function updatePreview(){
    fields.forEach(f => {
      const v = ($(f).value || '').toString().trim();
      $('p-'+f).textContent = v || '—';
    });
    // sync preview card-screen text (already updated)
    try {
      const obj = {}; fields.forEach(f => obj[f] = $(f).value); localStorage.setItem('supportCard', JSON.stringify(obj));
    } catch(e){}
  }

  // initial render
  updatePreview();

  // removed the update button listener (auto-updates on input)
  $('clear').addEventListener('click', ()=>{
    fields.forEach(f => $(f).value = '');
    updatePreview();
    try { localStorage.removeItem('supportCard'); } catch(e){}
  });

  function esc(s){
    if(!s) return '';
    return s.toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // PRINT: larger, centered, A4-ready
  $('print').addEventListener('click', ()=>{
    updatePreview();
    const data = {};
    fields.forEach(f => data[f] = $(f).value ? $(f).value.toString().trim() : '—');

    // precise print CSS: A4 page, centered vertically and horizontally, card width 160mm
    const printCSS = `
      <style>
        @page { size: A4 portrait; margin: 12mm; }
        html,body { height: 100%; margin: 0; padding: 0; }
        body{ font-family: Arial, Helvetica, sans-serif; -webkit-print-color-adjust: exact; color: var(--text-primary); }
        /* center the card on the page */
        .page-wrap { min-height: 100vh; display:flex; align-items:center; justify-content:center; padding:0; box-sizing:border-box; }
        .card{ width:160mm; max-width:100%; border:1px solid color-mix(in srgb, var(--brand-muted) 85%, var(--brand-light) 15%); padding:14mm; border-radius:6px; box-sizing:border-box; background: var(--brand-light); }
        .card-title{ font-weight:700; font-size:20px; margin-bottom:10px; color: var(--brand-dark); }
        .card-line{ margin:8px 0; font-size:15px; line-height:1.4; color: var(--text-primary); }
        .card-label{ font-weight:700; color: var(--text-muted); display:block; font-size:12px; margin-bottom:4px; }
        /* ensure no extra UI elements print */
        @media print {
          button, input { -webkit-print-color-adjust: none; }
        }
      </style>`;

    const html = `
      <!doctype html>
      <html>
        <head>
          <meta charset="utf-8">
          <title>Support Card</title>
          ${printCSS}
        </head>
        <body>
          <div class="page-wrap">
            <div class="card" role="region" aria-label="Support Card">
              <div class="card-title">My Support Card</div>
              <div class="card-line"><span class="card-label">Name:</span>${esc(data.name)}</div>
              <div class="card-line"><span class="card-label">How I like to be told things:</span>${esc(data.how)}</div>
              <div class="card-line"><span class="card-label">Sensory triggers:</span>${esc(data.sensory)}</div>
              <div class="card-line"><span class="card-label">What helps me:</span>${esc(data.helps)}</div>
              <div class="card-line"><span class="card-label">Money support:</span>${esc(data.money)}</div>
              <div class="card-line"><span class="card-label">Health note:</span>${esc(data.health)}</div>
              <div class="card-line"><span class="card-label">What builds my confidence:</span>${esc(data.confident)}</div>
              <div class="card-line"><span class="card-label">Emergency contact:</span>${esc(data.contact)}</div>
              <div class="card-line" style="margin-top:12px; font-size:13px; color:var(--text-muted);"><strong>How to use:</strong> Give this card to my teacher, carer or doctor.</div>
            </div>
          </div>
        </body>
      </html>`;

    const w = window.open('', '_blank');
    if (!w) {
      // Popup blocked — fallback: open printable content in same tab via blob
      const blob = new Blob([html], {type: 'text/html'});
      const url = URL.createObjectURL(blob);
      window.location.href = url;
      return;
    }

    w.document.open();
    w.document.write(html);
    w.document.close();
    w.focus();

    // Slightly longer delay to allow fonts & layout to settle on slow devices
    setTimeout(() => {
      try { w.print(); } catch(e) { console.error('Print failed', e); }
    }, 520);
  });

  // live update on typing (debounced)
  let t;
  fields.forEach(f => {
    $(f).addEventListener('input', ()=> {
      clearTimeout(t);
      t = setTimeout(updatePreview, 180);
    });
  });
</script>
</MainLayout>
