---
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";
---

<MainLayout activePage="positive message" pageTitle={`${siteConfig.title} — Positive Message`}>
  <div class="page-content max-w-2xl mx-auto text-left">
    <div class="rounded-lg p-6 bg-white/70 dark:bg-black/60 shadow-sm">
      <h1 class="text-2xl">Positive Message</h1>
      <p class="kanit-regular mt-3">Share uplifting messages, stories of resilience, and community highlights to inspire and comfort readers.</p>
    </div>
  </div>
</MainLayout>
