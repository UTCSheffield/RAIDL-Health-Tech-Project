---
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";
---

<MainLayout activePage="help" pageTitle={`${siteConfig.title}  -  Get Help`}>
  <div class="page-content px-4 sm:px-8">
    <section class="mb-12">
      <h1 class="text-4xl mb-4">Need Help? We're Here</h1>
      <p class="kanit-regular text-lg">If you're struggling or have questions, friendly services and people are available to help.</p>
    </section>

    <!-- Emergency/Crisis Support -->
    <section class="mb-12 p-6 rounded-lg bg-red-50 border-l-4 border-violet-red">
      <h2 class="text-2xl mb-4">Feeling Upset? Talk to Someone Now</h2>
      <p class="kanit-regular mb-4">If you're feeling distressed or thinking about harming yourself, you are not alone. These services are available 24/7:</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 kanit-regular">
        <div class="bg-white p-4 rounded">
          <p class="font-bold text-lg mb-1">Childline</p>
          <p class="text-xl font-bold text-violet-red mb-2">0800 1111</p>
          <p class="text-sm">Free and confidential for under-19s. Call or use online chat anytime.</p>
        </div>
        <div class="bg-white p-4 rounded">
          <p class="font-bold text-lg mb-1">Samaritans</p>
          <p class="text-xl font-bold text-violet-red mb-2">116 123</p>
          <p class="text-sm">Call 24/7 for emotional support.</p>
        </div>
        <div class="bg-white p-4 rounded">
          <p class="font-bold text-lg mb-1">Emergency services</p>
          <p class="text-xl font-bold text-violet-red mb-2">999</p>
          <p class="text-sm">Call if there is immediate danger or serious injury.</p>
        </div>
        <div class="bg-white p-4 rounded">
          <p class="font-bold text-lg mb-1">Text support</p>
          <p class="text-xl font-bold text-violet-red mb-2">Text HELLO to 50808</p>
          <p class="text-sm">Free, confidential text messages 24/7.</p>
        </div>
      </div>
    </section>

    <!-- Understanding Autism -->
    <section class="mb-12">
      <div class="rounded-lg p-6 bg-white/70 shadow-sm">
        <h2 class="text-2xl mb-3">Am I Autistic? Getting Answers</h2>
        <p class="kanit-regular mb-4">If you think you might be autistic or notice different ways of thinking, try these steps:</p>
        <ol class="kanit-regular list-decimal pl-6 space-y-3 mb-4">
          <li><strong>Talk to someone you trust</strong>  -  a parent, teacher or counsellor.</li>
          <li><strong>See your GP</strong>  -  explain your concerns so they can refer you to local services.</li>
          <li><strong>Specialist assessment</strong>  -  local teams can assess needs and suggest support.</li>
        </ol>
      </div>
    </section>

    <!-- Support at School -->
    <section class="mb-12">
      <div class="rounded-lg p-6 bg-white/70 shadow-sm">
        <h2 class="text-2xl mb-3">Help at School</h2>
        <p class="kanit-regular mb-4">Schools can provide specific support to help with learning and wellbeing.</p>
        <div class="space-y-3">
          <div>
            <p class="font-bold">SENCO</p>
            <p class="kanit-regular text-sm">Ask the Special Educational Needs Co-ordinator about available support.</p>
          </div>
          <div>
            <p class="font-bold">Adjustments</p>
            <p class="kanit-regular text-sm">Examples: extra time in tests, a quiet space, or different ways to work.</p>
          </div>
          <div>
            <p class="font-bold">EHCP</p>
            <p class="kanit-regular text-sm">An Education, Health and Care Plan sets out long-term support. Parents and carers can request an assessment.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Therapies & Support -->
    <section class="mb-12">
      <h2 class="text-2xl mb-4">Support and Therapy</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="rounded-lg p-6 bg-white/70 shadow-sm">
          <h3 class="text-xl mb-2">Talking support</h3>
          <p class="kanit-regular mb-3">Counsellors and therapists help with anxiety, low mood and stress. Ask your GP or school about referrals.</p>
        </div>

        <div class="rounded-lg p-6 bg-white/70 shadow-sm">
          <h3 class="text-xl mb-2">Speech and language therapy</h3>
          <p class="kanit-regular mb-3">Supports communication and understanding in everyday situations.</p>
        </div>

        <div class="rounded-lg p-6 bg-white/70 shadow-sm">
          <h3 class="text-xl mb-2">Occupational therapy</h3>
          <p class="kanit-regular mb-3">Helps with daily tasks and sensory issues like noise or touch.</p>
        </div>

        <div class="rounded-lg p-6 bg-white/70 shadow-sm">
          <h3 class="text-xl mb-2">Groups and activities</h3>
          <p class="kanit-regular mb-3">Local groups provide practical tips and a place to meet others.</p>
        </div>
      </div>
    </section>

    <!-- Resources & Websites -->
    <section class="mb-12">
      <div class="rounded-lg p-6 bg-white/70 shadow-sm">
        <h2 class="text-2xl mb-4">Websites and Resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 kanit-regular">
          <div>
            <p class="font-bold">The National Autistic Society</p>
            <p class="text-sm text-gray-700 mb-2">Guides, local services and practical advice.</p>
            <a href="https://www.autism.org.uk/" target="_blank" class="text-violet-red font-bold text-sm">Visit</a>
          </div>
          <div>
            <p class="font-bold">Autism UK</p>
            <p class="text-sm text-gray-700 mb-2">Information and community resources.</p>
            <a href="https://www.autismuk.org.uk/" target="_blank" class="text-violet-red font-bold text-sm">Visit</a>
          </div>
          <div>
            <p class="font-bold">Neurodiversity Hub</p>
            <p class="text-sm text-gray-700 mb-2">Resources on autism, ADHD and other differences.</p>
            <a href="https://www.neurodiversityhub.org/" target="_blank" class="text-violet-red font-bold text-sm">Visit</a>
          </div>
          <div>
            <p class="font-bold">Young Minds</p>
            <p class="text-sm text-gray-700 mb-2">Mental health support for young people.</p>
            <a href="https://www.youngminds.org.uk/" target="_blank" class="text-violet-red font-bold text-sm">Visit</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Money/Support -->
    <section class="mb-12">
      <div class="rounded-lg p-6 bg-white/70 shadow-sm">
        <h2 class="text-2xl mb-3">Money and practical support (for parents and carers)</h2>
        <p class="kanit-regular mb-4">Families may be eligible for financial help and practical services.</p>
        <ul class="kanit-regular list-disc pl-6 space-y-2 text-sm">
          <li><strong>Disability Living Allowance (DLA)</strong>  -  help with care and daily activities.</li>
          <li><strong>School support</strong>  -  in-school therapies and help with learning.</li>
          <li><strong>Local council support</strong>  -  short breaks, equipment and grants.</li>
        </ul>
        <p class="kanit-regular text-sm text-gray-700 mt-4">Contact your GP or local council for details and how to apply.</p>
      </div>
    </section>

    <!-- Reminder (removed from page but kept here in case you want it) -->
    <!--
    <section class="mb-8 p-6 rounded-lg bg-yellow-50 border-l-4 border-yellow-400">
      <p class="kanit-regular text-lg"><strong>Remember:</strong> You are not alone. There are people and services that want to help. It's okay to ask for support.</p>
    </section>
    -->
  </div>
</MainLayout>
