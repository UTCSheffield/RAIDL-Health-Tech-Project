---
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";
---

<MainLayout activePage="help" pageTitle={`${siteConfig.title} — Get Help`}>
  <div class="page-content px-4 sm:px-8">
    <section class="mb-12">
      <h1 class="text-4xl mb-4">Need Help? We're Here!</h1>
      <p class="kanit-regular text-lg">If you're struggling or have questions, there are lots of friendly people ready to listen and help.</p>
    </section>

    <!-- Emergency/Crisis Support -->
    <section class="mb-12 p-6 rounded-lg bg-red-50 border-l-4 border-violet-red">
      <h2 class="text-2xl mb-4">Feeling Upset? Talk to Someone Right Now</h2>
      <p class="kanit-regular mb-4">If you're feeling sad, scared, or having bad thoughts, you're not alone. These people are here 24/7 to listen:</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 kanit-regular">
        <div class="bg-white p-4 rounded">
          <p class="font-bold text-lg mb-1">Childline</p>
          <p class="text-xl font-bold text-violet-red mb-2">0800 1111</p>
          <p class="text-sm">Free, confidential. Talk to someone trained to help people like you. Chat online or call anytime.</p>
        </div>
        <div class="bg-white p-4 rounded">
          <p class="font-bold text-lg mb-1">Samaritans</p>
          <p class="text-xl font-bold text-violet-red mb-2">116 123</p>
          <p class="text-sm">Free to call anytime.</p>
        </div>
        <div class="bg-white p-4 rounded">
          <p class="font-bold text-lg mb-1">In Real Danger?</p>
          <p class="text-xl font-bold text-violet-red mb-2">999</p>
          <p class="text-sm">Call if someone is hurt or in immediate danger. Emergency help.</p>
        </div>
        <div class="bg-white p-4 rounded">
          <p class="font-bold text-lg mb-1">Crisis Text Line</p>
          <p class="text-xl font-bold text-violet-red mb-2">Text HELLO to 50808</p>
          <p class="text-sm">Free, confidential text support. Available 24/7.</p>
        </div>
      </div>
    </section>

    <!-- Understanding Autism -->
    <section class="mb-12">
      <div class="rounded-lg p-6 bg-white/70 shadow-sm">
        <h2 class="text-2xl mb-3">🧠 Am I Autistic? Getting Answers</h2>
        <p class="kanit-regular mb-4">If you think you might be autistic or just think differently:</p>
        <ol class="kanit-regular list-decimal pl-6 space-y-3 mb-4">
          <li><strong>Talk to a trusted adult</strong> — parent, school teacher, or counsellor</li>
          <li><strong>Visit your GP</strong> — they can refer you to a specialist doctor</li>
          <li><strong>Get an assessment</strong> — a doctor will chat with you to understand how your brain works</li>
          <li><strong>Get a diagnosis</strong> — this helps you understand yourself better and get support</li>
        </ol>
        <p class="kanit-regular text-sm bg-blue-50 p-3 rounded">💡 <strong>Remember:</strong> Being autistic isn't something that's wrong with you. It's just how your brain works. Lots of cool, creative, amazing people are autistic!</p>
      </div>
    </section>

    <!-- Support at School -->
    <section class="mb-12">
      <div class="rounded-lg p-6 bg-white/70 shadow-sm">
        <h2 class="text-2xl mb-3">🎓 Help at School</h2>
        <p class="kanit-regular mb-4">Your school can help you succeed:</p>
        <div class="space-y-3">
          <div>
            <p class="font-bold">🎯 SENCO (Special Needs Helper)</p>
            <p class="kanit-regular text-sm">A teacher at your school who helps kids who need extra support. Ask to talk to them!</p>
          </div>
          <div>
            <p class="font-bold">⚙️ Adjustments</p>
            <p class="kanit-regular text-sm">Things that can help you learn better — like extra time, quiet spaces, or different ways to do work.</p>
          </div>
          <div>
            <p class="font-bold">📝 EHCP (Extra Help Plan)</p>
            <p class="kanit-regular text-sm">A formal plan that makes sure your school gives you the support you need. Your parents can ask for this.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Therapies & Support -->
    <section class="mb-12">
      <h2 class="text-2xl mb-4">💪 Different Ways We Can Help You</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Talking Support -->
        <div class="rounded-lg p-6 bg-white/70 shadow-sm">
          <h3 class="text-xl mb-2">💬 Talking to Someone</h3>
          <p class="kanit-regular mb-3">A counsellor or therapist listens and helps you work through feelings and worries. Totally confidential.</p>
          <p class="kanit-regular text-sm text-gray-700">Ask your school, GP, or parents for a referral.</p>
        </div>

        <!-- Speech Therapy -->
        <div class="rounded-lg p-6 bg-white/70 shadow-sm">
          <h3 class="text-xl mb-2">🗣️ Speech & Language Help</h3>
          <p class="kanit-regular mb-3">A therapist helps with communication — whether it's speaking, listening, or understanding others.</p>
          <p class="kanit-regular text-sm text-gray-700">Great for making friends and being understood.</p>
        </div>

        <!-- Occupational Therapy -->
        <div class="rounded-lg p-6 bg-white/70 shadow-sm">
          <h3 class="text-xl mb-2">🎨 Occupational Therapy</h3>
          <p class="kanit-regular mb-3">Helps with things like writing, coordination, or managing sensory feelings (loud noises, textures).</p>
          <p class="kanit-regular text-sm text-gray-700">Makes everyday stuff easier and more comfortable.</p>
        </div>

        <!-- Groups & Activities -->
        <div class="rounded-lg p-6 bg-white/70 shadow-sm">
          <h3 class="text-xl mb-2">👥 Groups & Friends</h3>
          <p class="kanit-regular mb-3">Autism-friendly groups where you can meet other kids who get it. No judgment, just fun.</p>
          <p class="kanit-regular text-sm text-gray-700">Great for making friends with people like you.</p>
        </div>
      </div>
    </section>

    <!-- Resources & Websites -->
    <section class="mb-12">
      <div class="rounded-lg p-6 bg-white/70 shadow-sm">
        <h2 class="text-2xl mb-4">📱 Awesome Websites & Resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 kanit-regular">
          <div>
            <p class="font-bold">🌟 The National Autistic Society</p>
            <p class="text-sm text-gray-700 mb-2">Lots of info about autism, tips for school/friends, and stories from autistic people.</p>
            <a href="https://www.autism.org.uk/" target="_blank" class="text-violet-red font-bold text-sm">Visit →</a>
          </div>
          <div>
            <p class="font-bold">🤝 Autism UK</p>
            <p class="text-sm text-gray-700 mb-2">Real advice from autistic people. Great for understanding yourself better.</p>
            <a href="https://www.autismuk.org.uk/" target="_blank" class="text-violet-red font-bold text-sm">Visit →</a>
          </div>
          <div>
            <p class="font-bold">🧠 Neurodiversity Hub</p>
            <p class="text-sm text-gray-700 mb-2">All about ADHD, autism, dyslexia, and other ways of thinking.</p>
            <a href="https://www.neurodiversityhub.org/" target="_blank" class="text-violet-red font-bold text-sm">Visit →</a>
          </div>
          <div>
            <p class="font-bold">💻 Mind (Young Minds)</p>
            <p class="text-sm text-gray-700 mb-2">Mental health support for teens. Honest info about feelings and wellbeing.</p>
            <a href="https://www.youngminds.org.uk/" target="_blank" class="text-violet-red font-bold text-sm">Visit →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Money/Support -->
    <section class="mb-12">
      <div class="rounded-lg p-6 bg-white/70 shadow-sm">
        <h2 class="text-2xl mb-3">💰 Money & Support (For Parents/Carers)</h2>
        <p class="kanit-regular mb-4">Families can get help with costs:</p>
        <ul class="kanit-regular list-disc pl-6 space-y-2 text-sm">
          <li><strong>Disability Living Allowance (DLA)</strong> — Money to help with care and activities</li>
          <li><strong>School support</strong> — Free therapy and help at school</li>
          <li><strong>Local council support</strong> — Breaks for parents, equipment, grants</li>
        </ul>
        <p class="kanit-regular text-sm text-gray-700 mt-4">Ask a parent/carer to speak to the GP or council about what's available in your area.</p>
      </div>
    </section>

    <!-- Contact Us -->
    <section class="mb-12">
      <div class="rounded-lg p-6 bg-white/70 shadow-sm">
        <h2 class="text-2xl mb-4">💌 Want to Talk to Us?</h2>
        <p class="kanit-regular mb-4">Have a story to share? Questions? Want to help other kids? We'd love to hear from you.</p>
        <a href="/contact/" class="inline-flex items-center px-6 py-3 rounded-lg text-white font-bold hover:opacity-90 transition" style="background: linear-gradient(90deg, #fb8a56 0%, #8d3db8 100%);">Get in Touch</a>
      </div>
    </section>

    <!-- Reminder -->
    <section class="mb-8 p-6 rounded-lg bg-yellow-50 border-l-4 border-yellow-400">
      <p class="kanit-regular text-lg"><strong>Remember:</strong> You are not alone. There are lots of people who care about you and want to help. It's okay to ask for help. You're doing great! 💙</p>
    </section>
  </div>
</MainLayout>
