---
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";
---

<MainLayout activePage="fun stuff" pageTitle={`${siteConfig.title} — Fun Stuff`}>
  <div class="page-content mx-auto text-left">
    <div class="rounded-lg p-6 bg-white/70 dark:bg-black/60 shadow-sm">
      <h1 class="text-2xl">Fun Stuff</h1>
      <p class="kanit-regular mt-3">A collection of light-hearted activities, sensory-friendly games, and printable resources to enjoy. Add images, links, or small interactive elements here.</p>
    </div>
  </div>
</MainLayout>
