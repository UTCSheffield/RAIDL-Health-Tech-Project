---
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import { withBase } from "../utils/helpers";

--- 

<MainLayout activePage="home" pageTitle={siteConfig.title}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 dark:from-gray-900 dark:via-indigo-900 dark:to-purple-900 flex items-center px-4 py-20 overflow-hidden">
    <div class="w-full max-w-screen-xl mx-auto flex flex-col lg:flex-row items-center gap-16">
      <div class="flex-1 text-center lg:text-left z-10 hero-content">
        <h1 class="text-6xl lg:text-7xl font-bold bg-gradient-to-r from-orange-500 to-amber-500 bg-clip-text text-transparent mb-8 leading-tight" style="padding-bottom: 0;margin-bottom: 0;">
          RAIDL
        </h1>
        <p class="text-2xl lg:text-3xl text-gray-700 dark:text-gray-200 mb-12 leading-relaxed max-w-4xl">
          Informing young people about Autism. 
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center lg:justify-start">
          <a href={withBase("/articles/")}
             class="bg-gradient-to-r from-teal-500 to-cyan-500 hover:from-teal-600 hover:to-cyan-600 text-white px-10 py-5 rounded-full font-semibold text-xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
            Our Articles
          </a>
          <a href=#about-us
             class="bg-white/80 hover:bg-white text-teal-600 border-2 border-teal-600 px-10 py-5 rounded-full font-semibold text-xl transition-all duration-300 shadow-lg hover:shadow-xl backdrop-blur-sm">
            Learn More
          </a>
        </div>
      </div>

      <div class="flex-1 relative z-10 hero-image">
<figure
  id="image-rotator"
  data-base-url={withBase('/')}
  class="rounded-3xl shadow-2xl w-full aspect-[16/10] overflow-hidden relative"
>
   <img
  id="rotating-image"
  src={withBase('/images/autism-1.webp')}
  alt="Young person and support worker talking in a quiet room"
  class="w-full h-full object-cover transform transition-transform duration-500"
  loading="lazy"
  decoding="async"
/>
    <figcaption id="rotator-caption" class="text-sm text-gray-600 mt-2 sr-only">Photo credit</figcaption>
  </figure>
  </div>
  </div>
  </section>


  <!-- Flowing Mission Section -->
 <section id="about-us" class="relative py-0 px-4 bg-gradient-to-b from-white to-blue-50 dark:from-gray-800 dark:to-indigo-900 overflow-hidden">
  <div class="absolute inset-0 from-transparent via-blue-100/20 to-transparent dark:via-indigo-800/20"></div>
  <div class="relative max-w-screen-xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-5xl lg:text-6xl font-bold bg-gradient-to-r from-teal-600 to-cyan-600 bg-clip-text text-transparent mb-6">
        What is Autism?
      </h2>
      <p class="text-lg lg:text-xl text-gray-600 dark:text-gray-300 leading-relaxed max-w-3xl mx-auto">
        Autism is a lifelong difference that affects how people see the world, talk and learn. Everyone’s experience is unique. Some people need lots of support, others need little or none.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="bg-white/90 p-6 rounded-2xl shadow-lg">
        <h3 class="text-2xl font-semibold mb-3">Core traits</h3>
        <ul class="list-disc pl-5 space-y-2 text-gray-700 dark:text-gray-200">
          <li><strong>Differences in talking</strong> - challenges with non-verbal cues and conversation.</li>
          <li><strong>Restricted & repeating habits</strong> - routines, focused interests or repeated actions.</li>
          <li><strong>Change in senses</strong> - stronger or weaker responses to sounds, lights, touch or taste.</li>
        </ul>
        <p class="mt-4 text-sm text-gray-600 dark:text-gray-400">These traits change between people and are part of how someone experiences life.</p>
      </div>

      <div class="bg-white/90 p-6 rounded-2xl shadow-lg">
        <h3 class="text-2xl font-semibold mb-3">Signs</h3>
        <p class="text-gray-700 dark:text-gray-200 mb-3">Signs can appear early but sometimes show later.</p>
        
<details id="common-signs" open class="text-sm text-gray-600 dark:text-gray-400">
  <summary class="cursor-pointer font-medium">Common signs</summary>
  <ul class="list-disc pl-5 mt-2 space-y-1">
    <li>Limited eye contact or unusual social responses</li>
    <li>Delayed or repeating speech</li>
    <li>Different reactions to sensory input</li>
    <li>Strong interests</li>
  </ul>
</details>

      </div>
      
      <div class="bg-white/90 p-6 rounded-2xl shadow-lg">
        <h3 class="text-2xl font-semibold mb-3">Practical support</h3>
        <p class="text-gray-700 dark:text-gray-200 mb-3">Simple changes can make a big difference at school, home or socially:</p>
        <ul class="list-disc pl-5 text-gray-700 dark:text-gray-200 space-y-2">
          <li>Use clear language and give extra time.</li>
          <li>Offer quiet spaces or supports (headphones, dim lighting).</li>
          <li>Give visual schedules and give notice of changes.</li>
          <li>Work with their strengths and interests.</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 text-center">
      <p class="text-sm text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
        For a detailed guide, check the National Autistic Society and the NHS pages on autism. If you’re worried about yourself or a friend, your GP or local health services can advise about support.
      </p>
    </div>
  </div>
</section>

<!-- Replace your existing shapes section with this updated snippet.
     The description card now has a fixed width so its size won't change layout. -->
<section id="autism-spectrum" class="shapes-section" aria-labelledby="shapes-heading">
  <h2 id="shapes-heading" class="shapes-title text-center">Autism Spectrum</h2>
  <p class="shapes-sub">Austism isn't a line from least to most severe; it's many things which connect together in many different ways.</p>

  <div class="shapes-canvas" id="shapesCanvas" role="application" aria-describedby="shapes-desc">
    <svg id="shapesLines" class="shapes-lines" aria-hidden="true"></svg>

    <div class="shapes-grid" id="shapesGrid">
      <button class="shape circle" data-id="social" aria-label="Social communication">Talking and understanding</button>
     <button class="shape triangle" data-id="sensory" aria-label="Sensory experience">
  <span class="shape-text">Different<br>senses</span>
</button>
      <button class="shape square text-center" data-id="routines" aria-label="Routines and change">Habits &amp; change</button>
      <button class="shape blob" data-id="emotions" aria-label="Emotional regulation">Managing emotions</button>
      <button class="shape hexagon" data-id="focus" aria-label="Focus and interests">Focus &amp; interests</button>
      <button class="shape diamond" data-id="executive" aria-label="Executive functioning">Thinking skills</button>
    </div>
  </div>

  <!-- Fixed-width description card (does not change layout when text changes) -->
  <div id="shapeCard" class="shape-card" role="region" aria-live="polite" aria-hidden="true">
    <div class="shape-card__inner">
      <h3 class="text-center" id="cardTitle"></h3>
      <p class="text-center" id="cardText"></p>
    </div>
  </div>
</section>

<style>
  .shapes-section { padding: 28px 16px; max-width: 980px; margin: 0 auto; color: #0b1220; }
  .shapes-title { margin: 0 0 6px; font-size: 1.25rem; }
  .shapes-sub { margin: 0 0 18px; color: #6b7280; font-size: .95rem; }

  .shapes-canvas { position: relative; width: 100%; background: transparent; border-radius: 10px; }
  .shapes-lines { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }

  /* Grid of shapes (responsive) */
  .shapes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 18px;
    padding: 12px;
  }

  /* Generic shape styling */
  .shape {
    --size: 110px;
    height: var(--size);
    min-height: 84px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    box-sizing: border-box;
    border: none;
    cursor: pointer;
    user-select: none;
    transition: transform .16s ease, box-shadow .16s ease;
    text-align: center;
    font-weight: 700;
    color: #071023;
    line-height: 1.05;
    font-size: clamp(12px, 1.6vw, 14px);
    white-space: normal;
    word-break: break-word;
    border-radius: 14px;
    background: #f8fafc;
  }

  .shape:focus { outline: 3px solid rgba(59,130,246,0.18); outline-offset: 4px; }
  .shape.active { transform: translateY(-4px) scale(1.03); box-shadow: 0 10px 30px rgba(2,6,23,0.08); }

  .circle { border-radius: 999px; background: #dbeafe; }
  .triangle {
  background: #fef9c3;
  clip-path: polygon(50% 0%, 13% 95%, 85% 95%);
    /* reduce padding so text sits lower in triangle */
  display: flex;
  align-items: center;
  justify-content: center;
  
}


  .square { background: #dcfce7; border-radius: 12px; }
  .blob { background: #fee2e2; border-radius: 28% 72% 60% 40% / 40% 30% 70% 60%; }
  .hexagon { background: #ede9fe; clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%); }
  .diamond { background: #ccfbf1; clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%); }

  /* Fixed-width card: set explicit width so text changes don't reflow page */
  .shape-card {
    width: 640px;                 /* fixed width */
    max-width: calc(100% - 32px); /* responsive cap on very small screens */
    margin: 18px auto 0;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid #e6e9ef;
    background: #ffffff;
    box-shadow: 0 8px 24px rgba(2,6,23,0.04);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity .18s ease, transform .18s ease;
    /* keep layout stable: reserve space even when hidden */
    min-height: 72px;
  }
  .shape-card[aria-hidden="false"] { opacity: 1; transform: translateY(0); }

  .shape-card__inner { max-width: 600px; margin: 0 auto; } /* inner content narrower for nicer measure */
  .shape-card h3 { margin: 0 0 6px; font-size: 1rem; }
  .shape-card p { margin: 0; color: #475569; font-size: .95rem; }

  .shape .diamond{
     justify-self: center;   
  align-self: center;
  }

  @media (min-width: 720px) {
  /* make the grid a stable 3-column layout on larger screens */
  .shapes-grid {
    grid-template-columns: repeat(3, 1fr);
    grid-auto-flow: row;
  }

  /* force the diamond into the middle column / middle row */
  .shape.diamond {
    grid-column: 2;   /* second (middle) column */
    grid-row: 2;      /* second row (for a 3x2 grid this is the center) */
    justify-self: center;
    align-self: center;
    width: calc(var(--size) * 1.25);
  }
}
  @media (max-width: 720px) {
    .shape-card { width: 92%; }
    .shape { --size: 84px; font-size: clamp(11px, 2.6vw, 13px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .shape { transition: none; }
    .shape-card { transition: none; }
  }

  .shapes-canvas { position: relative; }      
.shapes-lines { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1; }
.shapes-grid  { position: relative; z-index: 2; } 
.shape         { z-index: 3; }   


/* REPLACE your existing .shape.click-anim block with this */
@keyframes clickPop {
  0%   { transform: translateY(0) scale(1); box-shadow: 0 6px 18px rgba(2,6,23,0.04); }
  40%  { transform: translateY(-8px) scale(1.08); box-shadow: 0 20px 42px rgba(2,6,23,0.12); }
  100% { transform: translateY(0) scale(1); box-shadow: 0 10px 30px rgba(2,6,23,0.08); }
}

/* ensure the animation wins over any transitions */
.shape.click-anim {
  animation: clickPop 360ms cubic-bezier(.2,.9,.3,1) both !important;
  will-change: transform, box-shadow;
}

/* Respect reduced-motion preference */
@media (prefers-reduced-motion: reduce) {
  .shape.click-anim { animation: none !important; transform: translateY(0) !important; box-shadow: none !important; }
}

</style>

<script is:inline>
  
  const DATA = {
  social: {
    title: "Talking and understanding",
    text: "How someone talks and listens. They may need extra time to answer or use different body language to show how they feel."
  },
  sensory: {
    title: "Different senses",
    text: "Sounds, lights, touch, smell or taste can feel too strong or not strong enough. Small changes like headphones or dim lights can help."
  },
  routines: {
    title: "Habits & change",
    text: "Routines help people feel safe. Sudden changes can be hard; a warning and a little time to adjust usually helps."
  },
  emotions: {
    title: "Managing emotions",
    text: "Feelings can become very big. The person might need help to calm down, take a break, or use a quiet space."
  },
  focus: {
    title: "Focus & interests",
    text: "Strong interests and deep focus are common. It can be hard to switch tasks or stop a task once started."
  },
  executive: {
    title: "Thinking skills",
    text: "Planning, starting tasks and managing time can be tricky. Breaking tasks into small steps and using a timer can help."
  }
};


  const shapesGrid = document.getElementById('shapesGrid');
  const shapes = Array.from(shapesGrid.querySelectorAll('.shape'));
  const svg = document.getElementById('shapesLines');
  const card = document.getElementById('shapeCard');
  const cardTitle = document.getElementById('cardTitle');
  const cardText = document.getElementById('cardText');
  const selected = new Set();

function drawConnections() {
  // clear existing lines
  while (svg.firstChild) svg.removeChild(svg.firstChild);

  const ids = Array.from(selected);
  if (ids.length < 2) return;

  // use the canvas element that contains the SVG and the grid
  const canvasEl = document.getElementById('shapesCanvas');
  const canvasRect = canvasEl.getBoundingClientRect();

  // size the svg to exactly match the canvas pixel size and viewBox
  const w = Math.max(0, Math.round(canvasRect.width));
  const h = Math.max(0, Math.round(canvasRect.height));
  svg.setAttribute('width', w);
  svg.setAttribute('height', h);
  svg.setAttribute('viewBox', `0 0 ${w} ${h}`);
  svg.style.width = w + 'px';
  svg.style.height = h + 'px';

  // draw line between centers of selected shapes (centers measured relative to canvas)
  for (let i = 0; i < ids.length; i++) {
    for (let j = i + 1; j < ids.length; j++) {
      const aEl = document.querySelector(`[data-id="${ids[i]}"]`);
      const bEl = document.querySelector(`[data-id="${ids[j]}"]`);
      if (!aEl || !bEl) continue;

      const a = aEl.getBoundingClientRect();
      const b = bEl.getBoundingClientRect();

      // center points relative to the canvas top-left
      const x1 = (a.left + a.width / 2) - canvasRect.left;
      const y1 = (a.top  + a.height / 2) - canvasRect.top;
      const x2 = (b.left + b.width / 2) - canvasRect.left;
      const y2 = (b.top  + b.height / 2) - canvasRect.top;

      const line = document.createElementNS('http://www.w3.org/2000/svg','line');
      line.setAttribute('x1', x1);
      line.setAttribute('y1', y1);
      line.setAttribute('x2', x2);
      line.setAttribute('y2', y2);
      line.setAttribute('stroke', 'rgba(15,23,42,0.12)');
      line.setAttribute('stroke-width', '2');
      line.setAttribute('stroke-linecap', 'round');
      svg.appendChild(line);
    }
  }
}


  function showCard(id) {
    const d = DATA[id];
    if (!d) return;
    cardTitle.textContent = d.title;
    cardText.textContent = d.text;
    card.setAttribute('aria-hidden', 'false');
  }

  function hideCard() {
    card.setAttribute('aria-hidden', 'true');
  }



  // initial draw and resize handling
  function updateSvgOnResize() {
    drawConnections();
  }
  window.addEventListener('resize', updateSvgOnResize);
  window.addEventListener('load', drawConnections);

  // -- unified click animation + selection handler --

// playClickAnim helper (one copy only)
function playClickAnim(el) {
  if (!el) return;
  el.classList.remove('click-anim'); // restart
  void el.offsetWidth; // reflow
  el.classList.add('click-anim');

  el.addEventListener('animationend', function handler() {
    el.classList.remove('click-anim');
    el.removeEventListener('animationend', handler);
  }, { once: true });
}

shapes.forEach(btn => {
  // immediate pointer/touch feedback
  btn.addEventListener('pointerdown', (ev) => {
    if (!ev.pointerType || ['mouse','touch','pen'].includes(ev.pointerType)) {
      playClickAnim(btn);
    }
  });

  // keyboard users: play animation then trigger click handler
  btn.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      playClickAnim(btn);
      // allow click handler to run after animation class applied
      setTimeout(() => btn.click(), 0);
    }
  });

  // main click handler: toggle selection, show/hide card, draw lines
  btn.addEventListener('click', () => {
    const id = btn.dataset.id;
    if (!id) return;

    if (selected.has(id)) {
      selected.delete(id);
      hideCard();
    } else {
      selected.add(id);
      showCard(id);
    }

    // visual active state
    shapes.forEach(s => s.classList.toggle('active', selected.has(s.dataset.id)));

    // redraw lines
    drawConnections();
  });
});




  
</script>












  <section class="relative py-8 md:py-20 px-4 bg-gradient-to-r from-orange-500 via-amber-500 to-rose-500 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-orange-600/20 via-amber-600/20 to-rose-600/20" style="border-radius: 20%; margin-top: 40px; width: fit-content;"></div>

    <div class="relative text-center">
      <div class="mx-auto max-w-md">
        <button id="openPositiveMessages" class="bg-gradient-to-r from-orange-500 via-amber-500 to-rose-500 text-white px-6 py-3 md:px-12 md:py-6 rounded-full font-bold text-sm md:text-xl hover:bg-gray-100 transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1 w-full md:w-auto">
          If you're feeling down or just want a feel-good message use this!
        </button>
      </div>
    </div>
  </section>

  <section id="positiveMessageSection" class="hidden py-8 md:py-24 px-4 bg-gradient-to-b from-white to-indigo-50 dark:from-gray-900 dark:to-indigo-900" style="width:100%">
    <div class="mx-auto text-center w-full max-w-lg">
      <div class="rounded-2xl p-4 md:p-8 bg-white/80 shadow-xl">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">Just for you...</h2>
        <p id="messageBox" class="text-base md:text-lg min-h-[56px] md:min-h-[80px] transition-opacity duration-300 mx-auto">Click the button when you’re ready.</p>
        <button id="generateBtn" class="px-4 py-2 md:px-6 md:py-3 rounded-full bg-teal-500 text-white font-semibold hover:bg-teal-600 transition-transform duration-200 hover:scale-105 text-sm md:text-base">
          Generate Message
        </button>
      </div>
    </div>
  </section>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const controls = document.getElementById('rotator-controls');
    if (!controls) return;

    const mode = document.documentElement.dataset.mode;

    if (mode === 'calm') {
      controls.hidden = false;
      controls.style.display = 'flex';
    }
  });
</script>
  <script is:inline>
    function initPositiveMessages() {
      const messages = [
    "You’re doing more than you notice; small steps add up.",
    "It’s okay to have a hard day. It doesn’t erase the progress you’ve made.",
    "Your needs matter. It’s perfectly fine to rest or ask for help.",
    "You’re allowed to take things one step at a time.",
    "What you’re feeling is valid. You don’t have to explain it to be respected.",
    "Progress isn’t always visible. Steady effort counts.",
    "You matter to people, even when it doesn’t feel obvious.",
    "If this feels heavy, try one small routine you can manage today.",
    "You’re learning even when it’s difficult. That itself is enough.",
    "A short break can help you come back with greater energy."
      ];

      const openBtn = document.getElementById('openPositiveMessages');
      const section = document.getElementById('positiveMessageSection');
      const generateBtn = document.getElementById('generateBtn');
      const box = document.getElementById('messageBox');

      if (!openBtn || !section) return;

      openBtn.onclick = () => {
        section.classList.remove('hidden');
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      };

      if (generateBtn && box) {
        generateBtn.onclick = () => {
          const randomIndex = Math.floor(Math.random() * messages.length);
          box.textContent = messages[randomIndex];
        };
      }
    }

    document.addEventListener('DOMContentLoaded', initPositiveMessages);
    document.addEventListener('astro:page-load', initPositiveMessages);
  </script>

<script is:inline>
  (function () {
    document.addEventListener('DOMContentLoaded', () => {
      // Local image filenames (no leading slash). If you prefer full URLs, put them here.
      const images = [
        { src: 'images/autism-1.webp', alt: 'Child listening on his headphones' },
        { src: 'images/autism-2.webp', alt: 'Child playing with bricks'},
        { src: 'images/autism-3.webp', alt: 'Child playing with building blocks'}
      ];

      const imgEl = document.getElementById('rotating-image');
      const captionEl = document.getElementById('rotator-caption');
      const prevBtn = document.getElementById('rot-prev');
      const nextBtn = document.getElementById('rot-next');
      const toggleBtn = document.getElementById('rot-toggle');
      const rotator = document.getElementById('image-rotator');

      if (!imgEl || !rotator) {
        console.warn('Image rotator: required elements not found.');
        return;
      }

      // base url injected by Astro via data attribute (e.g. "/RAIDL---Health-Tech-Project/")
      const baseUrl = rotator.dataset.baseUrl || '/';

      // helper: build a usable src
      function makeSrc(path) {
        if (!path) return path;
        // absolute external URL? leave as-is
        if (/^https?:\/\//i.test(path)) return path;
        // starts with slash -> treat as absolute (but keep it, since it may already include base)
        if (path.startsWith('/')) return path;
        // otherwise prefix baseUrl (ensure exactly one slash)
        return baseUrl.replace(/\/$/, '') + '/' + path.replace(/^\//, '');
      }

      // Preload
      images.forEach(i => { const p = new Image(); p.src = makeSrc(i.src); });

      let idx = 0;
      const delayMs = 5000;
      let timer = null;
     
      let playing = true;
      const controls = document.getElementById('rotator-controls');

      function show(i) {
        const item = images[i];
        if (!item) return;
        imgEl.src = makeSrc(item.src);
        imgEl.alt = item.alt || '';
        if (captionEl) captionEl.textContent = item.credit || '';
      }

      function next() { idx = (idx + 1) % images.length; show(idx); }
      function prev() { idx = (idx - 1 + images.length) % images.length; show(idx); }

      function start() {
        if (timer) clearInterval(timer);
        if (!playing) return;
        timer = setInterval(next, delayMs);
        if (toggleBtn) { toggleBtn.textContent = 'Pause'; toggleBtn.setAttribute('aria-label', 'Pause slideshow'); }
      }
      function stop() {
        if (timer) { clearInterval(timer); timer = null; }
        if (toggleBtn) { toggleBtn.textContent = 'Play'; toggleBtn.setAttribute('aria-label', 'Play slideshow'); }
      }

      // initial
      show(idx);
      if (playing) start(); else if (toggleBtn) toggleBtn.textContent = 'Play';

      if (prevBtn) prevBtn.addEventListener('click', () => { prev(); if (playing) start(); });
      if (nextBtn) nextBtn.addEventListener('click', () => { next(); if (playing) start(); });
      if (toggleBtn) toggleBtn.addEventListener('click', () => { playing = !playing; if (playing) start(); else stop(); });

      rotator.addEventListener('mouseenter', () => { if (timer) clearInterval(timer); });
      rotator.addEventListener('mouseleave', () => { if (playing) start(); });
      rotator.addEventListener('focusin', () => { if (timer) clearInterval(timer); });
      rotator.addEventListener('focusout', () => { if (playing) start(); });

      rotator.addEventListener('keydown', (ev) => {
        if (ev.key === 'ArrowLeft') { prev(); if (playing) start(); }
        if (ev.key === 'ArrowRight') { next(); if (playing) start(); }
        if (ev.key === ' ' || ev.key === 'Spacebar') { ev.preventDefault(); playing = !playing; if (playing) start(); else stop(); }
      });

      if (!rotator.hasAttribute('tabindex')) rotator.tabIndex = 0;
      if (mode === 'calm') {
  playing = false; // stop auto-rotation
  stop();
}
    });
  })();
  
</script>


<script is:inline>
(function(){
  var TIPS = {
    level1: "Level 1: Mild support. May need small changes like clear instructions and quiet corners.",
    level2: "Level 2: Noticeable support. May need structured routines, sensory tools and social coaching.",
    level3: "Level 3: Regular support. May need one-to-one help, sensory planning and communication aids.",
    level4: "Level 4: High support. May need daily care plans, specialist therapies and environmental adjustments.",
    level5: "Level 5: Complex needs. Multi-disciplinary support, tailored education and health plans are common.",
    level6: "Level 6: Intensive support. Full-time care, specialist teams and personalised strategies."
  };

  var tipEl = document.getElementById('tip');
  if(!tipEl) return;
  var nodes = Array.prototype.slice.call(document.querySelectorAll('.spectrum-timeline .node'));

  function clearActive(){ nodes.forEach(function(n){ n.classList.remove('active'); }); }
  function showTip(key, node){
    tipEl.textContent = TIPS[key] || 'More info coming soon.';
    clearActive();
    if(node) node.classList.add('active');
  }

  nodes.forEach(function(btn){
    var key = btn.getAttribute('data-key');
    if(!key) return;
    btn.addEventListener('mouseenter', function(){ showTip(key, btn); });
    btn.addEventListener('focus', function(){ showTip(key, btn); });
    btn.addEventListener('click', function(){ showTip(key, btn); });
    btn.addEventListener('touchstart', function(e){ e.preventDefault(); showTip(key, btn); }, {passive:false});
  });

  document.addEventListener('keydown', function(e){
    var active = document.activeElement;
    if(!active || !active.classList || !active.classList.contains('node')) return;
    var idx = nodes.indexOf(active);
    if(idx === -1) return;
    if(e.key === 'ArrowRight' || e.key === 'ArrowDown'){ var next = nodes[(idx+1)%nodes.length]; next.focus(); showTip(next.getAttribute('data-key'), next); e.preventDefault(); }
    if(e.key === 'ArrowLeft' || e.key === 'ArrowUp'){ var prev = nodes[(idx-1+nodes.length)%nodes.length]; prev.focus(); showTip(prev.getAttribute('data-key'), prev); e.preventDefault(); }
  });
})();
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.spectrum-timeline__item');

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 }
      );

      items.forEach((item) => observer.observe(item));
    } else {
      items.forEach((item) => item.classList.add('is-visible'));
    }
  });
</script>


