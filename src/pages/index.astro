---
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import { withBase } from "../utils/helpers";
---

<MainLayout activePage="home" pageTitle={siteConfig.title}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 dark:from-gray-900 dark:via-indigo-900 dark:to-purple-900 min-h-screen flex items-center px-4 py-20 overflow-hidden">
    <div class="w-full max-w-screen-xl mx-auto flex flex-col lg:flex-row items-center gap-16">
      <div class="flex-1 text-center lg:text-left z-10 hero-content">
        <h1 class="text-6xl lg:text-7xl font-bold bg-gradient-to-r from-orange-500 to-amber-500 bg-clip-text text-transparent mb-8 leading-tight">
          Caring Hearts
        </h1>
        <p class="text-2xl lg:text-3xl text-gray-700 dark:text-gray-200 mb-12 leading-relaxed max-w-4xl">
          Informing young people about Autism. 
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center lg:justify-start">
          <a href={withBase("/help/")}
             class="bg-gradient-to-r from-teal-500 to-cyan-500 hover:from-teal-600 hover:to-cyan-600 text-white px-10 py-5 rounded-full font-semibold text-xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
            Get Support
          </a>
          <a href={withBase("/about-us/")}
             class="bg-white/80 hover:bg-white text-teal-600 border-2 border-teal-600 px-10 py-5 rounded-full font-semibold text-xl transition-all duration-300 shadow-lg hover:shadow-xl backdrop-blur-sm">
            Learn More
          </a>
        </div>
      </div>

      <div class="flex-1 relative z-10 hero-image">
<figure
  id="image-rotator"
  data-base-url={withBase('/')}
  class="rounded-3xl shadow-2xl w-full aspect-[16/10] overflow-hidden relative"
>
   <img
  id="rotating-image"
  src={withBase('/images/autism-1.webp')}
  alt="Young person and support worker talking in a quiet room"
  class="w-full h-full object-cover transform transition-transform duration-500"
  loading="lazy"
  decoding="async"
/>
    <figcaption id="rotator-caption" class="text-sm text-gray-600 mt-2 sr-only">Photo credit</figcaption>

<div
  id="rotator-controls"
  class="absolute left-4 bottom-4 z-20 flex gap-2"
  hidden
>
  <button id="rot-prev" type="button"
    class="px-3 py-1 rounded bg-white/80 hover:bg-white text-sm">
    Prev
  </button>
  <button id="rot-toggle" type="button"
    class="px-3 py-1 rounded bg-white/80 hover:bg-white text-sm">
    Pause
  </button>
  <button id="rot-next" type="button"
    class="px-3 py-1 rounded bg-white/80 hover:bg-white text-sm">
    Next
  </button>
</div>
  </figure>
</div>
    


  </section>

  <!-- Flowing Mission Section -->
  <section class="relative py-32 px-4 bg-gradient-to-b from-white to-blue-50 dark:from-gray-800 dark:to-indigo-900 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-blue-100/20 to-transparent dark:via-indigo-800/20"></div>
    <div class="relative max-w-screen-xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="text-5xl lg:text-6xl font-bold bg-gradient-to-r from-orange-500 to-amber-500 bg-clip-text text-transparent mb-8">
          Our Mission
        </h2>
        <p class="text-xl lg:text-2xl text-gray-600 dark:text-gray-300 leading-relaxed max-w-4xl mx-auto">
          At Caring Hearts we want to inform young people about Autism and how to help yourself or others who could be struggling with this condition.
          We believe that by spreading awareness and understanding, we can create an environment where everyone feels like they belong.
        </p>
      </div>

      <!-- <div class="flex flex-wrap justify-center gap-8 lg:gap-12">
        <div class="flex-1 min-w-80 max-w-md bg-gradient-to-br from-blue-100 to-indigo-200 dark:from-blue-900 dark:to-indigo-800 p-10 rounded-3xl shadow-xl">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">Accessible Resources</h3>
          <p class="text-gray-700 dark:text-gray-200 leading-relaxed">Easy-to-understand guides and information tailored for families and children.</p>
        </div>

        <div class="flex-1 min-w-80 max-w-md bg-gradient-to-br from-green-100 to-emerald-200 dark:from-green-900 dark:to-emerald-800 p-10 rounded-3xl shadow-xl">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">Community Support</h3>
          <p class="text-gray-700 dark:text-gray-200 leading-relaxed">Connect with others who understand your experiences and challenges.</p>
        </div>

        <div class="flex-1 min-w-80 max-w-md bg-gradient-to-br from-purple-100 to-violet-200 dark:from-purple-900 dark:to-violet-800 p-10 rounded-3xl shadow-xl">
          <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">Practical Guidance</h3>
          <p class="text-gray-700 dark:text-gray-200 leading-relaxed">Real-world tips and strategies from lived experiences and experts.</p>
        </div>
      </div> -->
    </div>
  </section>

  <section class="relative py-32 px-4 bg-gradient-to-r from-orange-500 via-amber-500 to-rose-500 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-orange-600/20 via-amber-600/20 to-rose-600/20" style="border-radius: 20%;"></div>

    <div class="relative text-center">
      <button id="openPositiveMessages" class="bg-white text-orange-600 px-12 py-6 rounded-full font-bold text-xl hover:bg-gray-100 transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
        If you're feeling down or just want a feel-good message use this!
      </button>
    </div>
  </section>

  <section id="positiveMessageSection" class="hidden py-24 px-4 bg-gradient-to-b from-white to-indigo-50 dark:from-gray-900 dark:to-indigo-900">
    <div class="mx-auto text-center" style="width:1000px;max-width:100%;">
      <div class="rounded-2xl p-8 bg-white/80 dark:bg-black/60 shadow-xl">
        <h2 class="text-3xl font-bold mb-4">Just for you...</h2>
        <p id="messageBox" class="mt-4 text-lg min-h-[80px] transition-opacity duration-300 mx-auto">Click the button when you’re ready.</p>
        <button id="generateBtn" class="mt-6 px-6 py-3 rounded-full bg-teal-500 text-white font-semibold hover:bg-teal-600 transition-transform duration-200 hover:scale-105">
          Generate Message
        </button>
      </div>
    </div>
  </section>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const controls = document.getElementById('rotator-controls');
    if (!controls) return;

    const mode = document.documentElement.dataset.mode;

    if (mode === 'calm') {
      controls.hidden = false;
      controls.style.display = 'flex';
    }
  });
</script>
  <script is:inline>
    function initPositiveMessages() {
      const messages = [
        "You are not broken — your way of experiencing the world is valid.",
        "It’s okay to move at your own pace. There is no deadline for being yourself.",
        "Your needs matter, even when they’re hard to explain.",
        "You’re allowed to rest without earning it.",
        "Being autistic is not a flaw — it’s part of who you are.",
        "You don’t have to go through this alone. Support exists, and you deserve it.",
        "Small steps still count. Progress looks different for everyone.",
        "Your experiences and feelings are real and worthy of respect.",
        "It’s okay if today is overwhelming. Tomorrow can be different.",
        "You are allowed to set boundaries that protect your wellbeing.",
        "You belong, exactly as you are."
      ];

      const openBtn = document.getElementById('openPositiveMessages');
      const section = document.getElementById('positiveMessageSection');
      const generateBtn = document.getElementById('generateBtn');
      const box = document.getElementById('messageBox');

      if (!openBtn || !section) return;

      openBtn.onclick = () => {
        section.classList.remove('hidden');
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      };

      if (generateBtn && box) {
        generateBtn.onclick = () => {
          const randomIndex = Math.floor(Math.random() * messages.length);
          box.textContent = messages[randomIndex];
        };
      }
    }

    document.addEventListener('DOMContentLoaded', initPositiveMessages);
    document.addEventListener('astro:page-load', initPositiveMessages);
  </script>

<script is:inline>
  (function () {
    document.addEventListener('DOMContentLoaded', () => {
      // Local image filenames (no leading slash). If you prefer full URLs, put them here.
      const images = [
        { src: 'images/autism-1.webp', alt: 'Child listening on his headphones' },
        { src: 'images/autism-2.webp', alt: 'Child playing with bricks'},
        { src: 'images/autism-3.webp', alt: 'Child playing with building blocks'}
      ];

      const imgEl = document.getElementById('rotating-image');
      const captionEl = document.getElementById('rotator-caption');
      const prevBtn = document.getElementById('rot-prev');
      const nextBtn = document.getElementById('rot-next');
      const toggleBtn = document.getElementById('rot-toggle');
      const rotator = document.getElementById('image-rotator');

      if (!imgEl || !rotator) {
        console.warn('Image rotator: required elements not found.');
        return;
      }

      // base url injected by Astro via data attribute (e.g. "/RAIDL---Health-Tech-Project/")
      const baseUrl = rotator.dataset.baseUrl || '/';

      // helper: build a usable src
      function makeSrc(path) {
        if (!path) return path;
        // absolute external URL? leave as-is
        if (/^https?:\/\//i.test(path)) return path;
        // starts with slash -> treat as absolute (but keep it, since it may already include base)
        if (path.startsWith('/')) return path;
        // otherwise prefix baseUrl (ensure exactly one slash)
        return baseUrl.replace(/\/$/, '') + '/' + path.replace(/^\//, '');
      }

      // Preload
      images.forEach(i => { const p = new Image(); p.src = makeSrc(i.src); });

      let idx = 0;
      const delayMs = 5000;
      let timer = null;
     
      let playing = true;
      const controls = document.getElementById('rotator-controls');

      function show(i) {
        const item = images[i];
        if (!item) return;
        imgEl.src = makeSrc(item.src);
        imgEl.alt = item.alt || '';
        if (captionEl) captionEl.textContent = item.credit || '';
      }

      function next() { idx = (idx + 1) % images.length; show(idx); }
      function prev() { idx = (idx - 1 + images.length) % images.length; show(idx); }

      function start() {
        if (timer) clearInterval(timer);
        if (!playing) return;
        timer = setInterval(next, delayMs);
        if (toggleBtn) { toggleBtn.textContent = 'Pause'; toggleBtn.setAttribute('aria-label', 'Pause slideshow'); }
      }
      function stop() {
        if (timer) { clearInterval(timer); timer = null; }
        if (toggleBtn) { toggleBtn.textContent = 'Play'; toggleBtn.setAttribute('aria-label', 'Play slideshow'); }
      }

      // initial
      show(idx);
      if (playing) start(); else if (toggleBtn) toggleBtn.textContent = 'Play';

      if (prevBtn) prevBtn.addEventListener('click', () => { prev(); if (playing) start(); });
      if (nextBtn) nextBtn.addEventListener('click', () => { next(); if (playing) start(); });
      if (toggleBtn) toggleBtn.addEventListener('click', () => { playing = !playing; if (playing) start(); else stop(); });

      rotator.addEventListener('mouseenter', () => { if (timer) clearInterval(timer); });
      rotator.addEventListener('mouseleave', () => { if (playing) start(); });
      rotator.addEventListener('focusin', () => { if (timer) clearInterval(timer); });
      rotator.addEventListener('focusout', () => { if (playing) start(); });

      rotator.addEventListener('keydown', (ev) => {
        if (ev.key === 'ArrowLeft') { prev(); if (playing) start(); }
        if (ev.key === 'ArrowRight') { next(); if (playing) start(); }
        if (ev.key === ' ' || ev.key === 'Spacebar') { ev.preventDefault(); playing = !playing; if (playing) start(); else stop(); }
      });

      if (!rotator.hasAttribute('tabindex')) rotator.tabIndex = 0;
      if (mode === 'calm') {
  playing = false; // stop auto-rotation
  stop();
}
    });
  })();
  
</script>


</MainLayout>

