---
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
---

<MainLayout activePage="home" pageTitle={siteConfig.title}>
  <div class="page-content">
    <section class="rounded-lg p-8 bg-white/80 dark:bg-black/60 shadow-sm">
      <h1 class="text-4xl mb-4">{siteConfig.title}</h1>
      <p class="kanit-regular text-lg">{siteConfig.description}</p>

      <div class="mt-8">
        <h2 class="text-2xl">Our mission</h2>
        <p class="kanit-regular mt-2">{siteConfig.about?.text || 'We provide trusted information and community support. Replace this with your mission statement.'}</p>
      </div>

      <div class="mt-8">
        <h2 class="roboto-slab-bold text-2xl">What you'll find here</h2>
        <ul class="mt-3 list-disc pl-6 kanit-regular">
          <li>Accessible resources and signposting</li>
          <li>Practical guides and lived experience</li>
          <li>Community messages and positive stories</li>
        </ul>
      </div>

      <div class="mt-8">
        <p class="kanit-regular">Looking for help? Visit our <a href="/support/" class="text-violet-red">Support</a> page or <a href="/contact/" class="text-violet-red">Contact</a> us.</p>
      </div>
    </section>
  </div>
</MainLayout>
