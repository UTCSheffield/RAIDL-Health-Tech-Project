---
import MainLayout from "../layouts/MainLayout.astro";
import siteConfig from "../site.config";
import { withBase } from "../utils/helpers";
---

<MainLayout activePage="home" pageTitle={siteConfig.title}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 dark:from-gray-900 dark:via-indigo-900 dark:to-purple-900 min-h-screen flex items-center px-4 py-20 overflow-hidden">
    <div class="w-full max-w-screen-xl mx-auto flex flex-col lg:flex-row items-center gap-16">
      <!-- Text Content -->
      <div class="flex-1 text-center lg:text-left z-10">
        <h1 class="text-6xl lg:text-7xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent mb-8 leading-tight">
          Caring Hearts
        </h1>
        <p class="text-2xl lg:text-3xl text-gray-700 dark:text-gray-200 mb-12 leading-relaxed max-w-4xl">
          Supporting families and children who think differently with compassion, resources, and community.
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center lg:justify-start">
          <a href={withBase("/help/")} class="bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white px-10 py-5 rounded-full font-semibold text-xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
            Get Support
          </a>
          <a href={withBase("/about-us/")} class="bg-white/80 hover:bg-white text-indigo-600 border-2 border-indigo-600 px-10 py-5 rounded-full font-semibold text-xl transition-all duration-300 shadow-lg hover:shadow-xl backdrop-blur-sm">
            Learn More
          </a>
        </div>
      </div>
      
      <!-- Image -->
      <div class="flex-1 relative z-10">
        <div class="relative">
          <img 
            src="https://picsum.photos/700/500?random=1" 
            alt="Inclusive and supportive community illustration" 
            class="rounded-3xl shadow-2xl w-full transform hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute -top-8 -left-8 bg-gradient-to-br from-yellow-400 to-orange-400 rounded-full p-6 shadow-xl animate-bounce">
            <span class="text-3xl">✨</span>
          </div>
          <div class="absolute -bottom-6 -right-6 bg-gradient-to-br from-pink-400 to-rose-400 rounded-full p-5 shadow-xl animate-pulse">
            <span class="text-2xl">💝</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Organic shapes -->
    <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-gradient-to-br from-blue-200 to-indigo-300 rounded-full opacity-30 animate-pulse"></div>
    <div class="absolute bottom-1/3 right-1/5 w-24 h-24 bg-gradient-to-br from-purple-200 to-pink-300 rounded-full opacity-40 animate-pulse delay-1000"></div>
    <div class="absolute top-2/3 left-1/6 w-16 h-16 bg-gradient-to-br from-green-200 to-teal-300 rounded-full opacity-50 animate-pulse delay-2000"></div>
  </section>

  <!-- Flowing Mission Section -->
  <section class="relative py-32 px-4 bg-gradient-to-b from-white to-blue-50 dark:from-gray-800 dark:to-indigo-900 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-blue-100/20 to-transparent dark:via-indigo-800/20"></div>
    <div class="relative max-w-screen-xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="text-5xl lg:text-6xl font-bold bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent mb-8">
          Our Mission
        </h2>
        <p class="text-xl lg:text-2xl text-gray-600 dark:text-gray-300 leading-relaxed max-w-4xl mx-auto">
          At Caring Hearts, we believe every child deserves to feel understood and supported. 
          We provide accessible resources, practical guidance, and a welcoming community to help 
          families navigate the journey of neurodivergence with confidence and compassion.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-8 lg:gap-12">
        <div class="flex-1 min-w-80 max-w-md bg-gradient-to-br from-blue-100 to-indigo-200 dark:from-blue-900 dark:to-indigo-800 p-10 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
          <div class="w-20 h-20 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
            <span class="text-white text-3xl">📚</span>
          </div>
          <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">Accessible Resources</h3>
          <p class="text-gray-700 dark:text-gray-200 leading-relaxed">Easy-to-understand guides and information tailored for families and children.</p>
        </div>
        
        <div class="flex-1 min-w-80 max-w-md bg-gradient-to-br from-green-100 to-emerald-200 dark:from-green-900 dark:to-emerald-800 p-10 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
          <div class="w-20 h-20 bg-gradient-to-br from-green-500 to-emerald-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
            <span class="text-white text-3xl">🤝</span>
          </div>
          <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">Community Support</h3>
          <p class="text-gray-700 dark:text-gray-200 leading-relaxed">Connect with others who understand your experiences and challenges.</p>
        </div>
        
        <div class="flex-1 min-w-80 max-w-md bg-gradient-to-br from-purple-100 to-violet-200 dark:from-purple-900 dark:to-violet-800 p-10 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
          <div class="w-20 h-20 bg-gradient-to-br from-purple-500 to-violet-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
            <span class="text-white text-3xl">💡</span>
          </div>
          <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">Practical Guidance</h3>
          <p class="text-gray-700 dark:text-gray-200 leading-relaxed">Real-world tips and strategies from lived experiences and experts.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Organic Call to Action -->
  <section class="relative py-32 px-4 bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-600 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-700/20 via-purple-700/20 to-pink-700/20"></div>
    <div class="relative max-w-screen-xl mx-auto text-center">
      <h2 class="text-5xl lg:text-6xl font-bold mb-8 leading-tight">
        Ready to Get Started?
      </h2>
      <p class="text-2xl lg:text-3xl mb-12 opacity-90 max-w-3xl mx-auto leading-relaxed">
        Join our community of supportive families and discover resources that make a difference.
      </p>
      <div class="flex flex-col sm:flex-row gap-8 justify-center">
        <a href={withBase("/positive-message/")} class="bg-white text-indigo-600 px-12 py-6 rounded-full font-bold text-xl hover:bg-gray-100 transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
          Try Positive Messages
        </a>
        <a href={withBase("/contact/")} class="bg-transparent border-3 border-white text-white px-12 py-6 rounded-full font-bold text-xl hover:bg-white hover:text-indigo-600 transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
          Contact Us
        </a>
      </div>
    </div>
    
    <!-- Floating elements -->
    <div class="absolute top-1/4 left-1/4 w-20 h-20 bg-white/10 rounded-full animate-float"></div>
    <div class="absolute bottom-1/3 right-1/3 w-16 h-16 bg-white/10 rounded-full animate-float delay-1000"></div>
    <div class="absolute top-2/3 right-1/4 w-12 h-12 bg-white/10 rounded-full animate-float delay-2000"></div>
  </section>
</MainLayout>
