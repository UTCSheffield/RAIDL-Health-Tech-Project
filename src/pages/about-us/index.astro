---
import MainLayout from "../../layouts/MainLayout.astro";
import siteConfig from "../../site.config";
import { withBase } from "../../utils/helpers";
---

<MainLayout activePage="about us" pageTitle={`${siteConfig.title} — About Us`}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-green-50 via-teal-50 to-cyan-50 dark:from-gray-900 dark:via-teal-900 dark:to-cyan-900 py-32 px-4 overflow-hidden">
    <div class="w-full max-w-screen-xl mx-auto flex flex-col lg:flex-row items-center gap-16">
      <!-- Text Content -->
      <div class="flex-1 text-center lg:text-left z-10">
        <h1 class="text-6xl lg:text-7xl font-bold bg-gradient-to-r from-teal-600 to-cyan-600 bg-clip-text text-transparent mb-8 leading-tight">
          About Caring Hearts
        </h1>
        <p class="text-2xl lg:text-3xl text-gray-700 dark:text-gray-200 mb-12 leading-relaxed max-w-2xl">
          We're dedicated to supporting families and children with autism and neurodivergence through compassion, understanding, and practical resources.
        </p>
      </div>
      
      <!-- Image -->
      <div class="flex-1 relative z-10">
        <div class="relative">
          <img 
            src="https://picsum.photos/700/500?random=2" 
            alt="Team collaboration and support illustration" 
            class="rounded-3xl shadow-2xl w-full transform hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute -top-6 -left-6 bg-gradient-to-br from-teal-400 to-cyan-400 rounded-full p-6 shadow-xl animate-bounce">
            <span class="text-3xl">🌿</span>
          </div>
          <div class="absolute -bottom-8 -right-8 bg-gradient-to-br from-green-400 to-emerald-400 rounded-full p-5 shadow-xl animate-pulse">
            <span class="text-2xl">💚</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Organic shapes -->
    <div class="absolute top-1/3 left-1/5 w-28 h-28 bg-gradient-to-br from-teal-200 to-cyan-300 rounded-full opacity-30 animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-20 h-20 bg-gradient-to-br from-green-200 to-emerald-300 rounded-full opacity-40 animate-pulse delay-1000"></div>
    <div class="absolute top-1/2 right-1/6 w-16 h-16 bg-gradient-to-br from-blue-200 to-teal-300 rounded-full opacity-50 animate-pulse delay-2000"></div>
  </section>

  <!-- Flowing Mission Section -->
  <section class="relative py-32 px-4 bg-gradient-to-b from-white to-teal-50 dark:from-gray-800 dark:to-teal-900 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-teal-100/20 to-transparent dark:via-teal-800/20"></div>
    <div class="relative max-w-screen-xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="text-5xl lg:text-6xl font-bold bg-gradient-to-r from-teal-600 to-cyan-600 bg-clip-text text-transparent mb-8">
          Our Mission
        </h2>
        <p class="text-xl lg:text-2xl text-gray-600 dark:text-gray-300 leading-relaxed max-w-4xl mx-auto">
          At Caring Hearts, we believe that every child deserves to feel seen, heard, and supported. 
          Our mission is to create safe spaces, raise awareness, and connect families to meaningful support 
          through accessible resources and community connection.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-12 lg:gap-16">
        <div class="flex-1 min-w-96 max-w-lg bg-gradient-to-br from-teal-100 to-cyan-200 dark:from-teal-900 dark:to-cyan-800 p-12 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-3">
          <div class="w-24 h-24 bg-gradient-to-br from-teal-500 to-cyan-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg">
            <span class="text-white text-4xl">👥</span>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 dark:text-white mb-6">Who We Are</h3>
          <p class="text-lg text-gray-700 dark:text-gray-200 leading-relaxed">Caring Hearts is a community-driven initiative founded by parents, educators, and professionals who understand the unique challenges and joys of supporting neurodivergent children.</p>
        </div>

        <div class="flex-1 min-w-96 max-w-lg bg-gradient-to-br from-cyan-100 to-blue-200 dark:from-cyan-900 dark:to-blue-800 p-12 rounded-3xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-3">
          <div class="w-24 h-24 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg">
            <span class="text-white text-4xl">🎯</span>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 dark:text-white mb-6">What We Do</h3>
          <p class="text-lg text-gray-700 dark:text-gray-200 leading-relaxed">We provide trusted information, practical guides, and community connections. From diagnosis support to daily living tips, we're here to help families navigate their journey.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Organic Values Section -->
  <section class="relative py-32 px-4 bg-gradient-to-br from-purple-50 via-pink-50 to-indigo-50 dark:from-gray-900 dark:via-purple-900 dark:to-indigo-900 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-100/20 via-pink-100/20 to-indigo-100/20 dark:from-purple-800/20 dark:via-pink-800/20 dark:to-indigo-800/20"></div>
    <div class="relative max-w-screen-xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="text-5xl lg:text-6xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent mb-8">
          Our Values
        </h2>
        <p class="text-2xl lg:text-3xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">
          These principles guide everything we do
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-8 lg:gap-12">
        <div class="text-center transform hover:scale-110 transition-all duration-300">
          <div class="w-32 h-32 bg-gradient-to-br from-purple-400 to-indigo-500 rounded-3xl flex items-center justify-center mb-8 mx-auto shadow-xl hover:shadow-2xl">
            <span class="text-white text-5xl">🤝</span>
          </div>
          <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">Inclusivity</h3>
          <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed max-w-sm">Everyone belongs, and every voice matters in our community.</p>
        </div>

        <div class="text-center transform hover:scale-110 transition-all duration-300">
          <div class="w-32 h-32 bg-gradient-to-br from-pink-400 to-rose-500 rounded-3xl flex items-center justify-center mb-8 mx-auto shadow-xl hover:shadow-2xl">
            <span class="text-white text-5xl">💙</span>
          </div>
          <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">Compassion</h3>
          <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed max-w-sm">We approach every interaction with empathy and understanding.</p>
        </div>

        <div class="text-center transform hover:scale-110 transition-all duration-300">
          <div class="w-32 h-32 bg-gradient-to-br from-indigo-400 to-purple-500 rounded-3xl flex items-center justify-center mb-8 mx-auto shadow-xl hover:shadow-2xl">
            <span class="text-white text-5xl">🔍</span>
          </div>
          <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">Accessibility</h3>
          <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed max-w-sm">Information should be clear, simple, and available to all.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Organic Call to Action -->
  <section class="relative py-32 px-4 bg-gradient-to-r from-teal-600 via-cyan-600 to-blue-600 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-teal-700/20 via-cyan-700/20 to-blue-700/20"></div>
    <div class="relative max-w-screen-xl mx-auto text-center">
      <h2 class="text-5xl lg:text-6xl font-bold mb-8 leading-tight">
        Join Our Community
      </h2>
      <p class="text-2xl lg:text-3xl mb-12 opacity-90 max-w-3xl mx-auto leading-relaxed">
        Connect with families who understand, access valuable resources, and find the support you need.
      </p>
      <div class="flex flex-col sm:flex-row gap-8 justify-center">
        <a href={withBase("/contact/")} class="bg-white text-teal-600 px-12 py-6 rounded-full font-bold text-xl hover:bg-gray-100 transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
          Get in Touch
        </a>
        <a href={withBase("/fun-stuff/")} class="bg-transparent border-3 border-white text-white px-12 py-6 rounded-full font-bold text-xl hover:bg-white hover:text-teal-600 transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
          Explore Resources
        </a>
      </div>
    </div>
    
    <!-- Floating elements -->
    <div class="absolute top-1/4 left-1/4 w-24 h-24 bg-white/10 rounded-full animate-float"></div>
    <div class="absolute bottom-1/3 right-1/3 w-18 h-18 bg-white/10 rounded-full animate-float delay-1000"></div>
    <div class="absolute top-2/3 right-1/5 w-14 h-14 bg-white/10 rounded-full animate-float delay-2000"></div>
  </section>
</MainLayout>
