---
const {
  activePage,
  links,
  isMobileLink = false,
} = Astro.props as {
  activePage: string;
  links: { text: string; href: string }[];
  isMobileLink?: boolean;
};
---

{
  links?.map((link) => {
    const isActive = activePage === link.text.toLowerCase();
    const base = isMobileLink
      ? "block w-full text-left px-4 py-3 text-base"
      : "inline-block px-4 py-2 text-base";
    const theme = isActive
      ? "text-violet-red dark:text-tan-hide font-semibold"
      : "text-gray-800 dark:text-whitesmoke hover:opacity-80";

    return (
      <a class={`${base} ${theme} rounded-md transition`} href={link.href}>
        {link.text}
      </a>
    );
  })
}
