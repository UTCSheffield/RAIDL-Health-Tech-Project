<div id="chatwidget-root" class="fixed bottom-6 right-6 z-[99999]">

  <!-- Floating round button -->
  <button
    id="cw-launch"
    aria-controls="cw-panel"
    aria-expanded="false"
    class="cw-fab"
    title="Open chat"
  >
    <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="none">
      <path d="M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
        stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>

  <!-- Chat panel -->
  <aside
    id="cw-panel"
    class="cw-panel"
    aria-hidden="true"
    role="dialog"
    aria-label="Chat panel"
  >
    <header class="cw-header">
      <strong>Caring Hearts — Chat</strong>
      <button id="cw-close" class="cw-close" aria-label="Close">✕</button>
    </header>

    <div id="cw-body" class="cw-body">Welcome — click the input to send a message.</div>

    <div class="cw-input">
      <input id="cw-input" class="cw-input-el" placeholder="Type a message..." />
      <button id="cw-send" class="cw-send">Send</button>
    </div>
  </aside>
</div>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const panel = document.getElementById("cw-panel");
  const btnLaunch = document.getElementById("cw-launch");
  const btnClose = document.getElementById("cw-close");
  const body = document.getElementById("cw-body");
  const input = document.getElementById("cw-input");
  const btnSend = document.getElementById("cw-send");

  function openPanel() {
    panel.setAttribute("aria-hidden", "false");
    btnLaunch.setAttribute("aria-expanded", "true");
    input.focus();
  }

  function closePanel() {
    panel.setAttribute("aria-hidden", "true");
    btnLaunch.setAttribute("aria-expanded", "false");
  }

  btnLaunch.addEventListener("click", () => {
    const hidden = panel.getAttribute("aria-hidden") === "true";
    hidden ? openPanel() : closePanel();
  });

  btnClose.addEventListener("click", closePanel);

  function addMessage(text, from = "bot") {
    const d = document.createElement("div");
    d.className = "msg " + (from === "user" ? "user" : "bot");
    d.textContent = text;
    body.appendChild(d);
    body.scrollTop = body.scrollHeight;
  }

  btnSend.addEventListener("click", () => {
    const v = input.value.trim();
    if (!v) return;
    addMessage(v, "user");
    input.value = "";
    addMessage("Example message.", "bot");
  });

  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter") btnSend.click();
    if (e.key === "Escape") closePanel();
  });
});
</script>
