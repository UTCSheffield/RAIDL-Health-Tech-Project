---
import siteConfig, { type Link } from "../site.config";
import Hamburger from "./Hamburger.astro";
import SiteIdentity from "./SiteIdentity.astro";
import NavLinks from "./NavLinks.astro";
import { withBase } from "../utils/helpers";
const { activePage } = Astro.props;
---

<header id="site-header" class="sticky top-0 z-50 bg-white/80 backdrop-blur-sm transition-transform duration-300">
  <nav class="flex items-center justify-between w-full px-6 py-4" style="background-color: rgba(251,236,93, 0.4); border-radius: 0 0 15px 15px; ">
    <div class="flex items-center gap-6">
      <a href={withBase("/")} aria-label="Home"><SiteIdentity /></a>
    </div>

    <!-- Desktop Links -->
    <div class="hidden sm:flex sm:items-center sm:gap-8">
      <NavLinks activePage={activePage} links={siteConfig.headerNavLinks} />
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-4">
      <a href={withBase("/help/")} class="hidden sm:inline-flex items-center px-5 py-2 rounded-lg text-white font-bold caveat-brush-regular get-help-btn" style="background: linear-gradient(90deg, #fb8a56 0%, #8d3db8 100%); color: white !important;">Get Help</a>
      <button id="hamburger-menu" aria-controls="mobile-links" aria-expanded="false" class="sm:hidden inline-block" title="Menu">🍔</button>
    </div>
  </nav>

  <!-- Mobile menu (hidden by default) -->
  <div id="mobile-links" class="fixed inset-0 z-40 hidden bg-black/60 backdrop-blur-sm p-6">
    <div class="bg-white dark:bg-black rounded-lg max-w-md w-full mx-auto p-6">
      <div class="flex items-center justify-between mb-4">
        <SiteIdentity />
        <button id="mobile-close" aria-label="Close menu">❌</button>
      </div>
      <nav class="flex flex-col gap-2">
        <NavLinks activePage={activePage} links={siteConfig.headerNavLinks} isMobileLink={true} />
        <a href={withBase("/help/")} class="mt-4 inline-flex items-center px-4 py-2 rounded-lg text-white font-bold caveat-brush-regular get-help-btn" style="background: linear-gradient(90deg, #fb8a56 0%, #8d3db8 100%); color: white !important;">Get Help</a>
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  const hamburger = document.querySelector("#hamburger-menu");
  const mobile = document.querySelector("#mobile-links");
  const closeBtn = document.querySelector("#mobile-close");

  function openMobile() {
    if (!mobile) return;
    mobile.classList.remove("hidden");
    mobile.setAttribute("aria-hidden", "false");
    hamburger?.setAttribute("aria-expanded", "true");
    // move focus to first link for accessibility
    const firstLink = mobile.querySelector("a, button");
    firstLink?.focus();
    document.documentElement.style.overflow = "hidden";
  }

  function closeMobile() {
    if (!mobile) return;
    mobile.classList.add("hidden");
    mobile.setAttribute("aria-hidden", "true");
    hamburger?.setAttribute("aria-expanded", "false");
    hamburger?.focus();
    document.documentElement.style.overflow = "auto";
  }

  hamburger?.addEventListener("click", openMobile);
  closeBtn?.addEventListener("click", closeMobile);
  mobile?.addEventListener("click", (e) => {
    if (e.target === mobile) closeMobile();
  });

  // close with Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMobile();
  });

  // Hide/show header on scroll: hide when scrolling down, show when scrolling up
  (function () {
    const header = document.getElementById("site-header");
    if (!header) return;
    let lastScroll = window.scrollY || document.documentElement.scrollTop;
    let ticking = false;

    function onScroll() {
      const current = window.scrollY || document.documentElement.scrollTop;
      const delta = current - lastScroll;

      if (Math.abs(delta) < 10) return; // ignore small changes

      if (delta > 0 && current > 80) {
        // scrolled down
        header.classList.add('header-hidden');
      } else {
        // scrolled up
        header.classList.remove('header-hidden');
      }

      lastScroll = current <= 0 ? 0 : current;
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>
